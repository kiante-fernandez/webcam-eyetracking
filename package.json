{
  "name": "webcam-eyetracking-compendium",
  "type": "module",
  "version": "1.0.0",
  "description": "A comprehensive directory of webcam-based eye-tracking software and platforms",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "validate-data": "tsx src/scripts/validate-data.ts",
    "generate-export": "tsx src/scripts/generate-export.ts",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.ts",
    "link-check": "linkinator dist/ --recurse --skip '(github|doi)\\.'"
  },
  "dependencies": {
    "astro": "^5.16.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/preact": "^3.5.3",
    "@astrojs/sitemap": "^3.2.2",
    "@astrojs/tailwind": "^6.0.2",
    "@axe-core/playwright": "^4.10.0",
    "@octokit/rest": "^21.0.2",
    "@playwright/test": "^1.49.1",
    "@types/node": "^24.10.1",
    "@vitest/ui": "^2.1.8",
    "linkinator": "^6.1.2",
    "playwright": "^1.49.1",
    "preact": "^10.27.1",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8",
    "zod": "^3.24.1"
  }
}
