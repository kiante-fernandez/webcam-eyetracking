   if (iframe.contentWindow) {\n        iframe.contentWindow.postMessage({\n          type: 'viewport-update',\n          scrollX: window.scrollX,\n          scrollY: window.scrollY\n        }, '*');\n      }\n    }, 100);\n\n    gazeListener = function (event) {\n      if (!event.data || !event.data.type) return;\n\n      if (event.data.type === 'gaze-data') {\n        if (typeof event.data.x === 'number' && typeof event.data.y === 'number') {\n          gazeData.push([\n            Math.round(event.data.timestamp - trackingStartTime),\n            Math.round(event.data.x),\n            Math.round(event.data.y)\n          ]);\n        }\n      }\n    };\n    window.addEventListener('message', gazeListener);\n  });\n\n  Qualtrics.SurveyEngine.addOnPageSubmit(function () {\n    const iframe = document.getElementById('calibration-iframe');\n    if (iframe) {\n      iframe.contentWindow.postMessage({ type: 'pause-tracking' }, '*');\n    }\n\n    if (viewportInterval) clearInterval(viewportInterval);\n    if (gazeListener) window.removeEventListener('message', gazeListener);\n\n    Qualtrics.SurveyEngine.setEmbeddedData('gaze_' + questionId, JSON.stringify(gazeData));\n  });\n})('Q2');","RecodeValues":{"1":"0","2":"1","3":"2","4":"3","5":"4","6":"5","7":"6","8":"7","9":"8","10":"9","11":"10"}}},{"SurveyID":"SV_abD8KUns1FACIQu","Element":"SQ","PrimaryAttribute":"QID41","SecondaryAttribute":"\u00a0 \u00a0 Overall, how do you feel about your life these days? \u00a0 Move the slider to indicate how satisf","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\">&nbsp;<img src=\"https:\/\/sasupenn.qualtrics.com\/CP\/Graphic.php?IM=IM_86OrAFMGb8zEFrn\" style=\"width: 170px; height: 74px;\" \/><br \/>\n&nbsp;<\/div>\n\n<div style=\"text-align: center;\"><span style=\"font-size:24px;\"><strong>Overall, how do you feel about your life these days?<\/strong><\/span><\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: