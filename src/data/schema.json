{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "name", "slug", "tagline", "license", "primary_language", "last_verified", "verified_by"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique identifier in kebab-case"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Official name of the tool"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "URL-friendly slug for routing"
    },
    "tagline": {
      "type": "string",
      "maxLength": 150,
      "description": "Brief one-sentence description"
    },
    "short_impression": {
      "type": "string",
      "maxLength": 500,
      "description": "Neutral research tone summary"
    },
    "pros": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of advantages"
    },
    "cons": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of limitations"
    },
    "homepage": {
      "type": "string",
      "format": "uri",
      "description": "Official website URL"
    },
    "repo": {
      "type": "string",
      "format": "uri",
      "description": "Source code repository URL (GitHub preferred for metadata automation)"
    },
    "demo": {
      "type": "string",
      "format": "uri",
      "description": "Live demo or interactive example URL"
    },
    "docs": {
      "type": "string",
      "format": "uri",
      "description": "Official documentation URL"
    },
    "papers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "authors", "year"],
        "properties": {
          "title": {
            "type": "string"
          },
          "authors": {
            "type": "string"
          },
          "year": {
            "type": "integer",
            "minimum": 1990,
            "maximum": 2030
          },
          "doi": {
            "type": "string",
            "pattern": "^10\\."
          }
        }
      },
      "description": "Academic papers validating or describing the tool"
    },
    "license": {
      "type": "string",
      "enum": ["MIT", "Apache-2.0", "GPL-3.0", "BSD-3-Clause", "Proprietary", "Commercial", "Other"],
      "description": "Software license"
    },
    "primary_language": {
      "type": "string",
      "description": "Primary programming language"
    },
    "platform_support": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["Chrome", "Firefox", "Edge", "Safari", "Mobile", "Desktop", "iOS", "Android"]
      },
      "description": "Supported platforms and browsers"
    },
    "features": {
      "type": "object",
      "properties": {
        "gaze": {
          "type": "boolean"
        },
        "fixation": {
          "type": "boolean"
        },
        "heatmap": {
          "type": "boolean"
        },
        "blink_detection": {
          "type": "boolean"
        }
      },
      "description": "Supported eye-tracking features"
    },
    "calibration": {
      "type": "string",
      "enum": ["required", "optional", "none"],
      "description": "Calibration requirement"
    },
    "claimed_accuracy": {
      "type": "string",
      "description": "Accuracy claims (use '(claimed — cite vendor)' if not peer-reviewed)"
    },
    "privacy_notes": {
      "type": "string",
      "description": "Privacy and data handling notes"
    },
    "integration_guides": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["jsPsych", "Qualtrics", "oTree", "plain-html"]
      },
      "description": "Available integration guides"
    },
    "example_snippet": {
      "type": "string",
      "description": "Code example (open-source tools only)"
    },
    "media": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "url"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["screenshot", "gif", "video"]
          },
          "url": {
            "type": "string"
          },
          "attribution": {
            "type": "string"
          }
        }
      },
      "description": "Screenshots, GIFs, or videos"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Categorization tags (e.g., 'open-source', 'research', 'commercial')"
    },
    "last_verified": {
      "type": "string",
      "format": "date",
      "description": "Date when entry was last verified (YYYY-MM-DD)"
    },
    "verified_by": {
      "type": "string",
      "description": "Person or team who verified this entry"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "github_stars": {
          "type": "integer",
          "minimum": 0
        },
        "last_commit_date": {
          "type": "string",
          "format": "date"
        },
        "latest_release": {
          "type": "string"
        }
      },
      "description": "Auto-updated metadata from GitHub API"
    }
  }
}
