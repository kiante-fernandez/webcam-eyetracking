---
import Layout from '../../components/layout/Layout.astro';
import Badge from '../../components/common/Badge.astro';
import { getAllTools } from '../../data';
import type { Tool } from '../../types/tool';

export async function getStaticPaths() {
  const tools = getAllTools();
  return tools.map((tool) => ({
    params: { slug: tool.slug },
    props: { tool },
  }));
}

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;

const licenseVariant = tool.license.includes('MIT') || tool.license.includes('Apache') || tool.license.includes('BSD')
  ? 'success'
  : tool.license === 'GPL-3.0'
  ? 'info'
  : 'warning';
---

<Layout title={`${tool.name} | Webcam Eye-Tracking Compendium`} description={tool.tagline}>
  <div class="bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="mb-8">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">{tool.name}</h1>
        <p class="text-xl text-gray-600 mb-6">{tool.tagline}</p>
        <div class="flex flex-wrap gap-2">
          <Badge text={tool.license} variant={licenseVariant} />
          <Badge text={tool.primary_language} variant="gray" />
          {tool.calibration === 'none' && <Badge text="No calibration" variant="success" />}
          {tool.tags.includes('featured') && <Badge text="Featured" variant="primary" />}
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2">
          <section class="mb-8">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">Overview</h2>
            <p class="text-gray-700 leading-relaxed">{tool.short_impression}</p>
          </section>

          {tool.example_snippet && (
            <section class="mb-8">
              <h3 class="text-xl font-semibold text-gray-900 mb-3">Code Example</h3>
              <pre class="bg-gray-50 p-4 rounded-lg overflow-x-auto"><code>{tool.example_snippet}</code></pre>
            </section>
          )}

          {tool.privacy_notes && (
            <section class="mb-8">
              <h3 class="text-xl font-semibold text-gray-900 mb-3">Privacy & Data Handling</h3>
              <p class="text-gray-700">{tool.privacy_notes}</p>
            </section>
          )}
        </div>

        <div class="lg:col-span-1">
          <div class="bg-gray-50 p-6 rounded-lg sticky top-20">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Links</h3>

            <div class="space-y-3">
              {tool.homepage && (
                <a href={tool.homepage} class="block w-full btn btn-primary text-center" target="_blank" rel="noopener noreferrer">
                  Visit Website
                </a>
              )}
              {tool.repo && (
                <a href={tool.repo} class="block w-full btn btn-secondary text-center" target="_blank" rel="noopener noreferrer">
                  View Repository
                </a>
              )}
              {tool.demo && (
                <a href={tool.demo} class="block w-full btn btn-secondary text-center" target="_blank" rel="noopener noreferrer">
                  Try Demo
                </a>
              )}
              {tool.docs && (
                <a href={tool.docs} class="block w-full btn btn-secondary text-center" target="_blank" rel="noopener noreferrer">
                  Documentation
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
