---
import Layout from '../../components/layout/Layout.astro';

const base = import.meta.env.BASE_URL;

const guides = [
  {
    title: 'jsPsych Integration',
    description: 'Integrate webcam eye tracking into jsPsych experiments.',
    slug: 'jspsych',
    exampleUrl: 'https://www.jspsych.org/v7/demos/eye-tracking-with-webgazer.html',
    codeUrl: 'https://github.com/xiaozhi2/webgazertutorial'
  },
  {
    title: 'Qualtrics Integration',
    description: 'Add eye tracking to your Qualtrics surveys.',
    slug: 'qualtrics',
    exampleUrl: 'https://uclapsych.qualtrics.com/jfe/form/SV_abD8KUns1FACIQu',
    codeUrl: 'https://github.com/kiante-fernandez/webgazer-qualtrics'
  },
  {
    title: 'oTree Integration',
    description: 'Implement eye tracking in oTree for experimental economics tasks.',
    slug: 'otree'
  },
  {
    title: 'Plain HTML Demo',
    description: 'A minimal example showing to add eye tracking to any HTML page.',
    slug: 'plain-html',
    exampleUrl: `${base}/demos/plain-html-demo.html`,
    codeUrl: 'https://raw.githubusercontent.com/kiante-fernandez/webcam-eyetracking/refs/heads/main/public/demos/plain-html-demo.html'
  },
  {
    title: 'PsychoPy Integration',
    description: 'Integrate webcam eye tracking into PsychoPy experiments.',
    slug: 'psychopy',
    exampleUrl: 'https://run.pavlovia.org/tpronk/demo_eye_tracking2/',
    codeUrl: 'https://gitlab.pavlovia.org/tpronk/demo_eye_tracking2'
  }
];
---

<Layout title="Integration Guides | Webcam Eye-Tracking Compendium">
  <div class="bg-white py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-gray-900 mb-6">Integration Guides</h1>
      <p class="text-xl text-gray-700 mb-12">
        Step-by-step guides for integrating webcam eye tracking into popular research platforms and your own applications.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {guides.map((guide) => (
          <article class="card p-6">
            <h2 class="text-2xl font-semibold text-gray-900 mb-3">{guide.title}</h2>
            <p class="text-gray-600 mb-4">{guide.description}</p>
            {(guide.exampleUrl || guide.codeUrl) ? (
              <div class="flex gap-2">
                {guide.exampleUrl && (
                  <a href={guide.exampleUrl}
                     class="btn btn-primary"
                     target="_blank"
                     rel="noopener noreferrer">
                    Example
                  </a>
                )}
                {guide.codeUrl && (
                  <a href={guide.codeUrl}
                     class="btn btn-secondary"
                     target="_blank"
                     rel="noopener noreferrer">
                    Code
                  </a>
                )}
              </div>
            ) : (
              <div class="bg-white border border-gray-200 p-4 rounded text-center">
                <p class="text-sm text-gray-600">
                  Guide content coming in Phase 6
                </p>
              </div>
            )}
          </article>
        ))}
      </div>
    </div>
  </div>
</Layout>
