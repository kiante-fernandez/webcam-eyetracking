---
const currentYear = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="bg-gray-50 border-t border-gray-200 mt-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <h3 class="text-sm font-semibold text-gray-900 mb-3">About</h3>
        <p class="text-sm text-gray-600">
          A comprehensive, research-first compendium of webcam-based eye-tracking software, libraries, and experiment platforms.
        </p>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-gray-900 mb-3">Quick Links</h3>
        <ul class="space-y-2">
          <li>
            <a href={`${base}#guides`} class="text-sm text-gray-600 hover:text-primary-700">
              Integration Guides
            </a>
          </li>
          <li>
            <a href={`${base}#paper`} class="text-sm text-gray-600 hover:text-primary-700">
              Companion Paper
            </a>
          </li>
          <li>
            <a href={`${base}#about`} class="text-sm text-gray-600 hover:text-primary-700">
              About
            </a>
          </li>
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-gray-900 mb-3">Contributing</h3>
        <p class="text-sm text-gray-600 mb-2">
          Help us improve this compendium.
        </p>
        <a
          href="https://github.com/kiante-fernandez/webcam-eyetracking"
          class="text-sm text-primary-700 hover:text-primary-800 font-medium"
          target="_blank"
          rel="noopener noreferrer"
        >
          View on GitHub
        </a>
      </div>
    </div>
    <div class="mt-8 pt-8 border-t border-gray-200">
      <p class="text-sm text-gray-500 text-center">
        © {currentYear} Webcam Eye-Tracking Compendium. Licensed under MIT.
      </p>
    </div>
  </div>
</footer>

<style>
  @media (prefers-color-scheme: dark) {
    footer {
      background-color: #111827;
      border-color: #374151;
    }
  }
</style>
