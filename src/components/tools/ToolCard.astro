---
import type { Tool } from '../../types/tool';
import Badge from '../common/Badge.astro';

export interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
const base = import.meta.env.BASE_URL;

// Determine license badge variant
const licenseVariant = tool.license.includes('MIT') || tool.license.includes('Apache') || tool.license.includes('BSD')
  ? 'success'
  : tool.license === 'GPL-3.0'
  ? 'info'
  : 'warning';

// Get platform labels
const platformLabels: Record<string, string> = {
  'Chrome': 'Chrome',
  'Firefox': 'Firefox',
  'Edge': 'Edge',
  'Safari': 'Safari',
  'Desktop': 'Desktop',
  'Mobile': 'Mobile'
};
---

<article class="card p-6 h-full flex flex-col">
  <div class="flex items-start justify-between mb-3">
    <h3 class="text-xl font-semibold text-gray-900">
      <a href={`${base}/tools/${tool.slug}`} class="hover:text-primary-600">
        {tool.name}
      </a>
    </h3>
    {tool.metadata?.github_stars && (
      <div class="flex items-center text-sm text-gray-500">
        <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
        {tool.metadata.github_stars.toLocaleString()}
      </div>
    )}
  </div>

  <p class="text-gray-600 text-sm mb-4 line-clamp-2">
    {tool.tagline}
  </p>

  <div class="flex flex-wrap gap-2 mb-4">
    <Badge text={tool.license} variant={licenseVariant} size="sm" />
    <Badge text={tool.primary_language} variant="gray" size="sm" />
    {tool.calibration === 'none' && <Badge text="No calibration" variant="success" size="sm" />}
    {tool.tags.includes('featured') && <Badge text="Featured" variant="primary" size="sm" />}
  </div>

  <div class="flex flex-wrap gap-1 text-xs text-gray-600 mb-4">
    {tool.platform_support.slice(0, 4).map(platform => (
      <span class="px-2 py-0.5 bg-gray-100 rounded">{platformLabels[platform] || platform}</span>
    ))}
  </div>

  <div class="mt-auto pt-4 border-t border-gray-200">
    <div class="flex gap-3">
      {tool.homepage && (
        <a
          href={tool.homepage}
          class="text-sm text-primary-600 hover:text-primary-700"
          target="_blank"
          rel="noopener noreferrer"
        >
          Website
        </a>
      )}
      {tool.repo && (
        <a
          href={tool.repo}
          class="text-sm text-primary-600 hover:text-primary-700"
          target="_blank"
          rel="noopener noreferrer"
        >
          Repository
        </a>
      )}
      {tool.demo && (
        <a
          href={tool.demo}
          class="text-sm text-primary-600 hover:text-primary-700"
          target="_blank"
          rel="noopener noreferrer"
        >
          Demo
        </a>
      )}
    </div>
  </div>
</article>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
